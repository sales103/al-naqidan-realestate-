# =============================================================================
# شركة عبدالحكيم النقيدان للاستثمارات العقارية
# AI Real Estate Automation System - Environment Variables
# =============================================================================

# Application
NODE_ENV=production
APP_NAME=Al-Naqidan Real Estate AI
APP_VERSION=1.0.0
APP_PORT=3000
APP_URL=https://your-domain.com
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-replace-this-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Database - PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=naqidan_realestate
DB_USER=naqidan_user
DB_PASSWORD=your-strong-db-password-here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_TTL=3600
REDIS_CONVERSATION_TTL=86400

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.3

# WhatsApp - Evolution API
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-evolution-api-key-here
EVOLUTION_INSTANCE_NAME=naqidan-whatsapp
WHATSAPP_PHONE_NUMBER=+966XXXXXXXXX

# n8n
N8N_URL=http://n8n:5678
N8N_WEBHOOK_URL=https://your-domain.com/n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-n8n-password-here
N8N_ENCRYPTION_KEY=your-n8n-encryption-key-here

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=/app/logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# File Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
ALLOWED_VIDEO_TYPES=mp4,mov,avi
ALLOWED_DOC_TYPES=pdf

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@naqidan.com
ADMIN_EMAIL=admin@naqidan.com

# Security
CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
WEBHOOK_SECRET=your-webhook-secret-here

# Monitoring
GRAFANA_URL=http://grafana:3001
PROMETHEUS_URL=http://prometheus:9090

# Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=naqidan-backups
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=me-south-1
